# ==========================================================
# FILINGPULSE - DATA PIPELINE CONFIGURATION (TEAM A)
# ==========================================================

# --- Bright Data ---
# Bearer token for the SERP API (IR / filing page discovery)
BRIGHTDATA_SERP_API_KEY=your_brightdata_serp_api_key_here
# SERP API zone name (from your Bright Data dashboard)
BRIGHTDATA_SERP_ZONE=filingpulse_serp
# Web Unlocker proxy string to bypass bot detection on SEC + investor portals
# Format: http://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:33335
BRIGHTDATA_WEB_UNLOCKER_PROXY=http://user:password@brd.superproxy.io:33335

# --- Integration (JSON contract) ---
# Webhook where Team A POSTs the normalized diff payload (Team B listener).
# If unset or unreachable, the pipeline runs its built-in local simulator
# so the dashboard still shows alerts end-to-end.
TEAM_B_WEBHOOK_URL=http://localhost:4000/api/changes-receiver

# --- Database ---
# PostgreSQL connection string (matches docker-compose at the repo root)
DATABASE_URL=postgresql://filingpulse:filingpulse_secret@localhost:5432/filingpulse_db?schema=public

# --- Web server ---
PORT=3000
